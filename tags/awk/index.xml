</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># sed &#34;3c123\n456&#34; demo  #替换第3行内容</span>
</span></span><span class="line"><span class="cl">aaa
</span></span><span class="line"><span class="cl">bbbb
