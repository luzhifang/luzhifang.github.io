</span></span><span class="line"><span class="cl">bbbb
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># sed -n &#34;/aaa/,/DD/p&#34; demo</span>
