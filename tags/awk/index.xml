</span></span><span class="line"><span class="cl">awkdemo
</span></span><span class="line"><span class="cl">awkdemo
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># awk &#39;BEGIN {print ARGC}&#39; awkdemo awkdemo1</span>
