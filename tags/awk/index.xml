    </div><div class="highlight"><pre tabindex="0" class="chroma"><code class="language-Shell" data-lang="Shell"><span class="line"><span class="cl"><span class="c1"># select * FROM table ORDER BY RAND() LIMIT 2;</span>
</span></span><span class="line"><span class="cl">awk <span class="s1">&#39;BEGIN{srand();while(i&lt;2){k=int(rand()*10)+1;if(!(k in a)){a[k];i++}}}(NR in a)&#39;</span> table_file</span></span></code></pre></div></div>
