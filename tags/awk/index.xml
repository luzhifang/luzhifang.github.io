</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># awk &#39;BEGIN {print ARGV[0]}&#39; awkdemo awkdemo1</span>
</span></span><span class="line"><span class="cl">awk
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># awk &#39;BEGIN {print ARGV[1]}&#39; awkdemo awkdemo1</span>
</span></span><span class="line"><span class="cl">awkdemo
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># awk &#39;BEGIN {print ARGV[2]}&#39; awkdemo awkdemo1</span>
</span></span><span class="line"><span class="cl">awkdemo1</span></span></code></pre></div></div>
<h3 id="自定义变量">自定义变量</h3>
<div class="code-block code-line-numbers open" style="counter-reset: code-block 0">
