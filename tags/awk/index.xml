</span></span><span class="line"><span class="cl"><span class="m">5</span>
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># awk &#39;{print FNR}&#39; awkdemo awkdemo1</span>
</span></span><span class="line"><span class="cl"><span class="m">1</span>
