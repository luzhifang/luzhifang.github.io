</span></span><span class="line"><span class="cl">aaa
</span></span><span class="line"><span class="cl">bbbb
</span></span><span class="line"><span class="cl"><span class="m">123</span>
</span></span><span class="line"><span class="cl">AABBCCDD
</span></span><span class="line"><span class="cl"><span class="o">[</span>root@along ~<span class="o">]</span><span class="c1"># sed &#34;1i123&#34; demo  #在第1行前加123</span>
</span></span><span class="line"><span class="cl"><span class="m">123</span>
</span></span><span class="line"><span class="cl">aaa
</span></span><span class="line"><span class="cl">bbbb
