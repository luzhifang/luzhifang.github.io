</span></span><span class="line"><span class="cl">awk <span class="s1">&#39;{a[$1]}END{asorti(a);for(i=1;i&lt;=length(a);i++){print a[i]}}&#39;</span> table_file</span></span></code></pre></div></div>
<h4 id="取前多少条记录">取前多少条记录</h4>
<div class="code-block code-line-numbers open" style="counter-reset: code-block 0">
